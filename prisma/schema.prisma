generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum BookingStatus {
  PENDING
  ACCEPTED
  REJECTED
  COMPLETED
  CANCELLED
}

enum CarType {
  SWIFT
  ETIOS
  ERTIGA
  INNOVA
  TRAVELLER
}

model drivers {
  id         String     @id @default(uuid()) @db.VarChar(36)
  name       String     @db.VarChar(100)
  email      String     @unique @db.VarChar(255)
  password   String     @db.VarChar(255)
  phone      String?    @db.VarChar(15)
  isActive   Boolean    @default(true)
  created_at DateTime   @default(now()) @db.Timestamp(0)
  updated_at DateTime   @updatedAt @db.Timestamp(0)
  bookings   bookings[] @relation("DriverBookings")

  @@index([email])
  @@index([isActive])
  @@map("drivers")
}

model passengers {
  id         String     @id @default(uuid()) @db.VarChar(36)
  name       String     @db.VarChar(100)
  email      String     @unique @db.VarChar(255)
  password   String     @db.VarChar(255)
  phone      String?    @db.VarChar(15)
  isActive   Boolean    @default(true)
  created_at DateTime   @default(now()) @db.Timestamp(0)
  updated_at DateTime   @updatedAt @db.Timestamp(0)
  bookings   bookings[] @relation("PassengerBookings")

  @@index([email])
  @@index([isActive])
  @@map("passengers")
}

model bookings {
  id                String        @id @default(uuid()) @db.VarChar(36)
  car               CarType
  dateTime          DateTime      @db.DateTime(0)
  startLocation     String        @db.VarChar(500)
  endLocation       String        @db.VarChar(500)
  startLatitude     Decimal?      @db.Decimal(10, 8)
  startLongitude    Decimal?      @db.Decimal(11, 8)
  endLatitude       Decimal?      @db.Decimal(10, 8)
  endLongitude      Decimal?      @db.Decimal(11, 8)
  estimatedDistance Float?        @db.Float
  estimatedFare     Decimal?      @db.Decimal(8, 2)
  actualFare        Decimal?      @db.Decimal(8, 2)
  mobile            String        @db.VarChar(15)
  passengerName     String        @db.VarChar(100)
  specialRequests   String?       @db.Text
  status            BookingStatus @default(PENDING)
  created_at        DateTime      @default(now()) @db.Timestamp(0)
  updated_at        DateTime      @updatedAt @db.Timestamp(0)
  acceptedAt        DateTime?     @db.Timestamp(0)
  completedAt       DateTime?     @db.Timestamp(0)
  cancelledAt       DateTime?     @db.Timestamp(0)
  cancellationNote  String?       @db.Text

  // Foreign Keys
  passengerId       String        @db.VarChar(36)
  driverId          String?       @db.VarChar(36)

  // Relationships
  passenger         passengers    @relation("PassengerBookings", fields: [passengerId], references: [id], onDelete: Cascade)
  driver            drivers?      @relation("DriverBookings", fields: [driverId], references: [id], onDelete: SetNull)

  @@index([passengerId])
  @@index([driverId])
  @@index([status])
  @@index([dateTime])
  @@index([created_at])
  @@index([status, dateTime])
  @@map("bookings")
}
