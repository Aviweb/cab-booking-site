generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum BookingStatus {
  PENDING
  ACCEPTED
  REJECTED
  COMPLETED
  CANCELLED
}

enum CarType {
  SWIFT
  ETIOS
  ERTIGA
  INNOVA
  TRAVELLER
}

model drivers {
  id         String     @id @default(uuid())
  name       String
  email      String     @unique
  password   String
  phone      String?
  isActive   Boolean    @default(true)
  created_at DateTime   @default(now())
  updated_at DateTime   @updatedAt
  bookings   bookings[] @relation("DriverBookings")

  @@index([email])
  @@index([isActive])
  @@map("drivers")
}

model passengers {
  id         String     @id @default(uuid())
  name       String
  email      String     @unique
  password   String
  phone      String?
  isActive   Boolean    @default(true)
  created_at DateTime   @default(now())
  updated_at DateTime   @updatedAt
  bookings   bookings[] @relation("PassengerBookings")

  @@index([email])
  @@index([isActive])
  @@map("passengers")
}

model bookings {
  id                String        @id @default(uuid())
  car               CarType
  dateTime          DateTime
  startLocation     String
  endLocation       String
  startLatitude     Float?
  startLongitude    Float?
  endLatitude       Float?
  endLongitude      Float?
  estimatedDistance Float?
  estimatedFare     Float?
  actualFare        Float?
  mobile            String
  passengerName     String
  specialRequests   String?
  status            BookingStatus @default(PENDING)
  created_at        DateTime      @default(now())
  updated_at        DateTime      @updatedAt
  acceptedAt        DateTime?
  completedAt       DateTime?
  cancelledAt       DateTime?
  cancellationNote  String?

  // Foreign Keys
  passengerId       String
  driverId          String?

  // Relationships
  passenger         passengers    @relation("PassengerBookings", fields: [passengerId], references: [id], onDelete: Cascade)
  driver            drivers?      @relation("DriverBookings", fields: [driverId], references: [id], onDelete: SetNull)

  @@index([passengerId])
  @@index([driverId])
  @@index([status])
  @@index([dateTime])
  @@index([created_at])
  @@index([status, dateTime])
  @@map("bookings")
}
